# Hoist packages that Metro/Expo needs to resolve at the project root.
# Without this, pnpm's strict isolation breaks transitive dependency
# resolution for React Native bundlers (Metro, Babel, NativeWind).
public-hoist-pattern[]=*react-native*
public-hoist-pattern[]=*expo*
public-hoist-pattern[]=react-native-css-interop
public-hoist-pattern[]=*@react-navigation*
public-hoist-pattern[]=*nativewind*
